# Slack bridge environment variables
# Copy this file to .env.slack and fill in the real values.

# Bot User OAuth Token — starts with xoxb-
# Found at: api.slack.com/apps → your app → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# App-Level Token (Socket Mode) — starts with xapp-
# Found at: api.slack.com/apps → your app → Basic Information → App-Level Tokens
# Required scope: connections:write
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# Optional: comma-separated Slack member IDs that are allowed to send commands.
# Leave empty to allow anyone who can DM or mention the bot.
# Find your ID: Slack → click your name → "Copy member ID"
ALLOWED_USERS=
